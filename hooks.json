{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ./hooks/inject-state.ps1",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ./hooks/on-stop.ps1",
        "timeout": 10,
        "loop_limit": 2
      }
    ],
    "afterFileEdit": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ./hooks/on-after-edit.ps1",
        "matcher": "Write",
        "timeout": 10
      }
    ]
  }
}
